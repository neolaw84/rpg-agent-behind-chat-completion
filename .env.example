# API key for the LLM provider (OpenRouter, Z.AI, etc.)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Full completion API URL override (defaults to OpenRouter completions endpoint)
# OPENROUTER_BASE_URL=https://api.z.ai/api/paas/v4/chat/completions

# Optional: Default model fallback override if not specified in request payload
# DEFAULT_MODEL=google/gemini-flash-1.5

# Optional: Disable include_reasoning extra body parameters (defaults to true)
# RPG_AGENT_INCLUDE_REASONING=false
