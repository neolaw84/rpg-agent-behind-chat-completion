# RACHEL Proxy Environment Variables
# Service provider infrastructure secrets (e.g. database credentials or admin keys)

# Optional: Custom admin proxy API key (if unset, auto-generated in data/proxy.key)
# RACHEL_PROXY_KEY=your-secret-proxy-key

# Optional: PostgreSQL Database connection string for multi-tenant / postgres storage engine
# DATABASE_URL=postgresql://user:password@localhost:5432/rachel_db

# Note: LLM provider keys (OpenRouter BYOK/PKCE, OpenAI, Google Gemini, DeepSeek) are configured
# dynamically per user via the Admin Console GUI (http://localhost:8000).
